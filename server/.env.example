DATABASE_URL=postgresql://gotit:gotit@127.0.0.1:5434/gotit
JWT_SECRET=dev-secret-at-least-16-chars
JWT_EXPIRES_IN=7d

# 微信小程序（真机登录必填 AppSecret）
# 获取路径：mp.weixin.qq.com → 开发管理 → 开发设置 → AppSecret(小程序密钥)
WECHAT_MINI_APPID=wx703d7f44468c7dbf
WECHAT_MINI_SECRET=

# 仅本地无 Secret 时的占位 openid；配置 Secret 后请留空或删除此行
WECHAT_MINI_MOCK_OPENID=dev-openid-local

NODE_ENV=development
PORT=4000
HOST=0.0.0.0
PUBLIC_BASE_URL=http://127.0.0.1:4000
